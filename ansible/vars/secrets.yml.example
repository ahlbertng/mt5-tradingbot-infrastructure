---
# PRODUCTION SECRETS
# Encrypt this file: ansible-vault encrypt vars/secrets.yml
# Edit: ansible-vault edit vars/secrets.yml
# View: ansible-vault view vars/secrets.yml


# MT5 CREDENTIALS

mt5_login: "YOUR_MT5_DEMO_LOGIN"
mt5_password: "YOUR_MT5_DEMO_PASSWORD"
mt5_server: "ICMarketsSC-Demo"


# AWS CREDENTIALS (from Terraform output)

# Run: terraform output oracle_bot_secret_key
aws_access_key: "GET_FROM_TERRAFORM_OUTPUT"
aws_secret_key: "GET_FROM_TERRAFORM_OUTPUT"


# DATABASE PASSWORD (from terraform.tfvars)

db_password: "YOUR_TERRAFORM_DB_PASSWORD"


# MONITORING

grafana_password: "production_grafana_secure_password_123"


# BUSINESS INFORMATION (Optional - for reports)

organization: "Your Company Name"
contact_email: "devops@yourcompany.com"
incident_email: "alerts@yourcompany.com"