# MT5 Trading Bot — Local Development Environment
# Copy to .env and fill in real values before running docker-compose up
# Never commit .env to version control

# ── Database ────────────────────────────────────────────────────────────────
DB_ENDPOINT=postgres:5432
DB_NAME=trading_db
DB_USERNAME=trading_admin
DB_PASSWORD=change_me_strong_password
DB_CONNECT_TIMEOUT=10

# ── MT5 Credentials ─────────────────────────────────────────────────────────
MT5_LOGIN=your_mt5_account_number
MT5_PASSWORD=your_mt5_password
MT5_SERVER=ICMarketsSC-Demo

# ── AWS ─────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
# Leave blank for local dev — bot falls back to env-var MT5 credentials
SECRET_ARN=
# Leave blank for local dev — CloudWatch/S3/SNS calls will be skipped/logged
S3_BUCKET=
SNS_TOPIC_ARN=

# ── Risk Management ─────────────────────────────────────────────────────────
MAX_RISK_PER_TRADE=0.02
MAX_DAILY_LOSS=0.05
MAX_POSITIONS=3

# ── Application ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_PATH=/app/logs
MODEL_PATH=/app/models

# ── Grafana (optional monitoring UI on :3000) ───────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me_grafana_password

# ── pgAdmin (optional DB UI on :5050) ───────────────────────────────────────
PGADMIN_EMAIL=admin@trading.local
PGADMIN_PASSWORD=change_me_pgadmin_password
